{
  "name": "sports-management",
  "version": "0.3.0",
  "packageManager": "pnpm@9.15.4",
  "description": "Sports league management monorepo — Next.js web app, Convex backend, and Ink TUI",
  "type": "module",
  "scripts": {
    "check:css": "node scripts/check-css-comments.mjs",
    "check:env": "node scripts/check-web-env-parity.js",
    "check:launch": "node scripts/check-web-env-parity.js --launch",
    "tui": "pnpm --filter @sports-management/tui dev",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "husky": "^9.1.7",
    "semantic-release": "^25.0.3",
    "turbo": "^2.3.0"
  },
  "author": "Sports Management Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/andysolomon/sports-league-management.git"
  },
  "keywords": [
    "sports",
    "management",
    "league",
    "nextjs",
    "convex",
    "monorepo"
  ],
  "engines": {
    "node": ">=20.9.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.17",
      "@types/react-dom": "19.2.3"
    }
  }
}
