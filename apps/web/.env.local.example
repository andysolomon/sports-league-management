# Clerk Authentication
# Keep Clerk envs aligned between local and Vercel Production unless a planned
# migration says otherwise.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SIGNING_SECRET=whsec_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Convex
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_ADMIN_KEY=convex_admin_key_goes_here

# Legacy Salesforce JWT Bearer Flow
# Only needed for one-time migration/backfill scripts while moving existing
# records out of Salesforce.
SF_LOGIN_URL=https://login.salesforce.com
SF_CLIENT_ID=your_connected_app_client_id
SF_USERNAME=integration@example.com
SF_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_PLUS_MONTHLY=price_...
STRIPE_PRICE_PLUS_YEARLY=price_...
STRIPE_PRICE_CLUB_MONTHLY=price_...
STRIPE_PRICE_CLUB_YEARLY=price_...
STRIPE_PRICE_LEAGUE_MONTHLY=price_...
STRIPE_PRICE_LEAGUE_YEARLY=price_...

# Resend Email
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=billing@sprtsmng.andrewsolomon.dev

# App
# This is the one value that should differ by environment: localhost locally,
# deployed host in Vercel Production.
NEXT_PUBLIC_APP_URL=https://sprtsmng.andrewsolomon.dev
