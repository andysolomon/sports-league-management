{
  "name": "@sports-management/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "test:e2e:headed": "playwright test --config e2e/playwright.config.ts --headed",
    "test:e2e:report": "playwright test --config e2e/playwright.config.ts --reporter=html && playwright show-report",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.12.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@sports-management/api-contracts": "workspace:*",
    "@sports-management/shared-types": "workspace:*",
    "@vercel/analytics": "^2.0.1",
    "@vercel/og": "^0.11.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jsforce": "^3.6.0",
    "lucide-react": "^0.577.0",
    "next": "^15.3.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "resend": "^6.10.0",
    "sonner": "^2.0.7",
    "stripe": "^22.0.0",
    "svix": "^1.90.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@clerk/testing": "^1.4.0",
    "@eslint/eslintrc": "^3.0.0",
    "@playwright/test": "^1.50.0",
    "@tailwindcss/postcss": "^4.1.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.3.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.2"
  }
}
